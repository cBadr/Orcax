NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/platform

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS
WEB_ORIGIN=http://localhost:3000

# Super admin bootstrap (created by seed if not exists)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!

# SMTP (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Platform <noreply@example.com>"

# Paths
EXPORTS_DIR=./data/exports
UPLOADS_DIR=./data/uploads

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# CoinPayments (override admin-panel values only if you prefer env-config)
COINPAYMENTS_API_URL=https://a-api.coinpayments.net
COINPAYMENTS_CLIENT_ID=
COINPAYMENTS_CLIENT_SECRET=
COINPAYMENTS_WEBHOOK_SECRET=

# Public URL used in IPN callback + invoice return URLs
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WEB_URL=http://localhost:3000
