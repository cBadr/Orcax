# ==============================================================================
# PRODUCTION .env for the API — copy to apps/api/.env on the server
# ==============================================================================

NODE_ENV=production
PORT=4000
HOST=127.0.0.1

# ---- PostgreSQL ----
# Create user + db first:
#   CREATE USER platform WITH PASSWORD '<strong_password>';
#   CREATE DATABASE platform OWNER platform;
DATABASE_URL=postgresql://platform:CHANGE_ME@localhost:5432/platform

# ---- Redis (Memurai on Windows, or redis-server) ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
# Generate strong random strings (at least 32 chars):
#   powershell: -join ((1..48) | % { [char](Get-Random -Min 33 -Max 126) })
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_LONG_RANDOM_STRING
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Web origin(s) allowed by CORS (comma-separated) ----
WEB_ORIGIN=https://yourdomain.com

# ---- First super admin (created once by the seed script) ----
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_FIRST_LOGIN

# ---- SMTP (optional but recommended for transactional email) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Platform <noreply@yourdomain.com>"

# ---- File storage paths (data directory) ----
EXPORTS_DIR=./data/exports
UPLOADS_DIR=./data/uploads

# ---- Google OAuth (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/auth/google/callback

# ---- CoinPayments (configurable ALSO from /admin/settings) ----
# Leave blank here if you prefer to set them in the admin UI (stored in DB).
COINPAYMENTS_API_URL=https://a-api.coinpayments.net
COINPAYMENTS_CLIENT_ID=
COINPAYMENTS_CLIENT_SECRET=

# ---- Public URLs (used in invoice redirects + IPN webhook) ----
# MUST be real public HTTPS URLs for CoinPayments to accept them.
PUBLIC_API_URL=https://api.yourdomain.com
PUBLIC_WEB_URL=https://yourdomain.com
